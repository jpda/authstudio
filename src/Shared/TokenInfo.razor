<section class="panel mt-2">
    <h2 class="panel-title">Tokens</h2>
    <div class="field-grid">
        <label for="idToken">ID token</label>
        <div>
            <InputTextArea id="idToken" class="form-control form-control-sm mono" @bind-Value="Token.IdToken" rows="3" />
            <JwtInspector Jwt="@Token.IdToken" Label="ID token" JwtIoFragment="id_token" OpenByDefault="true" />
        </div>

        <label for="accessToken">Access token</label>
        <div>
            <InputTextArea id="accessToken" class="form-control form-control-sm mono" @bind-Value="Token.AccessToken" rows="3" />
            <JwtInspector Jwt="@Token.AccessToken" Label="access token" JwtIoFragment="access_token" OpenByDefault="true" />
        </div>

        <label for="refreshToken">Refresh token</label>
        <InputText id="refreshToken" class="form-control form-control-sm mono" @bind-Value="Token.RefreshToken" />

        <label for="expiresIn">Expires</label>
        <span id="expiresIn" class="mono">@Token.ExpiresAt.ToLocalTime()</span>

        <label for="tokenType">Type</label>
        <span id="tokenType">@Token.TokenType</span>

        <label for="scope">Scope</label>
        <code id="scope" class="mono">@Token.Scope</code>
    </div>
</section>

@code {
    [Parameter]
    public TokenResponseModel Token { get; set; } = new TokenResponseModel();
}
