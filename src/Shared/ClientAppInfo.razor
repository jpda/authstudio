@inject NavigationManager NavigationManager
@inject IPersistentSettingsRepository SettingsRepository

<section class="panel">
    <h2 class="panel-title">Client</h2>

    <p class="panel-hint">
        CIMD document: <code>@CimdUrl</code>
    </p>

    <div class="field-grid">
        <label for="clientId">Client ID</label>
        <InputText id="clientId" class="form-control form-control-sm mono" @bind-Value="ClientApp.ClientId"
            @bind-Value:after="PersistClientApp" />

        <label for="clientSecret">Client secret</label>
        <InputText id="clientSecret" class="form-control form-control-sm mono" @bind-Value="ClientApp.ClientSecret"
            @bind-Value:after="PersistClientApp" />

        <label for="redirectUri">Redirect URI</label>
        <InputText id="redirectUri" class="form-control form-control-sm mono" @bind-Value="ClientApp.RedirectUri"
            @bind-Value:after="PersistClientApp" />
    </div>
</section>

@code {
    private string CimdUrl => CimdDefaults.GetDocumentUrl(NavigationManager);

    [Parameter]
    public IssuerModel Issuer { get; set; } = new IssuerModel();

    [Parameter]
    public ClientAppModel ClientApp { get; set; } = new ClientAppModel();

    [Parameter]
    public EventCallback<ClientAppModel> ClientAppChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(ClientApp.RedirectUri))
        {
            ClientApp.RedirectUri = NavigationManager.ToAbsoluteUri("code").ToString();
        }

        if (CimdDefaults.ShouldDefaultClientId(ClientApp.ClientId, Issuer.ClientIdMetadataDocumentSupported))
        {
            ClientApp.ClientId = CimdUrl;
        }

        await PersistClientApp();
        await base.OnInitializedAsync();
    }

    private async Task PersistClientApp()
    {
        await SettingsRepository.SetClientAppModelAsync(ClientApp);
        await ClientAppChanged.InvokeAsync(ClientApp);
    }
}
