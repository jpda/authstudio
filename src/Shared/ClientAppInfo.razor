@inject NavigationManager NavigationManager
@inject IPersistentSettingsRepository SettingsRepository
@inject WorkspacePresetService WorkspacePresets
@inject HttpClient Http

<section class="panel">
    <h2 class="panel-title">Client</h2>

    <p class="panel-hint">
        Public CIMD: <code>@PublicCimdUrl</code><br />
        Private CIMD: <code>@PrivateCimdUrl</code> · JWKS: <a href="@JwksUrl" target="_blank" rel="noopener">jwks.json</a>
    </p>

    <div class="field-grid">
        <label for="clientId">Client ID</label>
        <InputText id="clientId" class="form-control form-control-sm mono" @bind-Value="ClientApp.ClientId"
            @bind-Value:after="PersistClientApp" />

        <label for="clientSecret">Client secret</label>
        <InputText id="clientSecret" class="form-control form-control-sm mono" @bind-Value="ClientApp.ClientSecret"
            @bind-Value:after="OnClientSecretChanged" />

        <label for="tokenAuthMethod">Token auth</label>
        <InputSelect id="tokenAuthMethod" class="form-select form-select-sm" @bind-Value="ClientApp.TokenAuthMethod"
            @bind-Value:after="OnTokenAuthMethodChanged">
            <option value="@TokenClientAuthMethod.None">None (public / PKCE)</option>
            <option value="@TokenClientAuthMethod.ClientSecretPost">Client secret (POST body)</option>
            <option value="@TokenClientAuthMethod.ClientSecretBasic">Client secret (Basic header)</option>
            <option value="@TokenClientAuthMethod.PrivateKeyJwt">private_key_jwt</option>
        </InputSelect>

        @if (ClientApp.TokenAuthMethod == TokenClientAuthMethod.PrivateKeyJwt)
        {
            <label for="signingAlgorithm">Signing alg</label>
            <InputSelect id="signingAlgorithm" class="form-select form-select-sm" @bind-Value="ClientApp.SigningAlgorithm"
                @bind-Value:after="PersistClientApp">
                <option value="ES256">ES256</option>
                <option value="RS256">RS256</option>
            </InputSelect>

            <label for="signingKey">Private JWK</label>
            <div>
                <textarea id="signingKey" class="form-control form-control-sm mono assertion-key-input" rows="5"
                    @bind="ClientApp.SigningPrivateKeyJwk" @bind:after="PersistClientApp"></textarea>
                <div class="panel-actions mt-1">
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="LoadIllustrativeSigningKey">
                        Load illustrative key
                    </button>
                    <a class="btn btn-outline-secondary btn-sm" href="assertion">Assertion generator</a>
                </div>
            </div>
        }

        <label for="redirectUri">Redirect URI</label>
        <InputText id="redirectUri" class="form-control form-control-sm mono" @bind-Value="ClientApp.RedirectUri"
            @bind-Value:after="PersistClientApp" />
    </div>
</section>

@code {
    private string PublicCimdUrl => CimdDefaults.GetDocumentUrl(NavigationManager);
    private string PrivateCimdUrl => CimdDefaults.GetPrivateClientDocumentUrl(NavigationManager);
    private string JwksUrl => CimdDefaults.GetJwksDocumentUrl(NavigationManager);

    [Parameter]
    public IssuerModel Issuer { get; set; } = new IssuerModel();

    [Parameter]
    public ClientAppModel ClientApp { get; set; } = new ClientAppModel();

    [Parameter]
    public EventCallback<ClientAppModel> ClientAppChanged { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(ClientApp.RedirectUri))
        {
            ClientApp.RedirectUri = NavigationManager.ToAbsoluteUri("code").ToString();
        }

        if (CimdDefaults.ShouldDefaultClientId(ClientApp.ClientId, Issuer.ClientIdMetadataDocumentSupported))
        {
            ClientApp.ClientId = PublicCimdUrl;
        }

        await SettingsRepository.SetClientAppModelAsync(ClientApp);
        await ClientAppChanged.InvokeAsync(ClientApp);
        await base.OnInitializedAsync();
    }

    private async Task LoadIllustrativeSigningKey()
    {
        ClientApp.SigningPrivateKeyJwk = await Http.GetStringAsync(CimdDefaults.GetSigningKeyDocumentUrl(NavigationManager));
        ClientApp.SigningAlgorithm = "ES256";
        await PersistClientApp();
    }

    private async Task OnClientSecretChanged()
    {
        if (!string.IsNullOrEmpty(ClientApp.ClientSecret) && ClientApp.TokenAuthMethod == TokenClientAuthMethod.None)
        {
            ClientApp.TokenAuthMethod = TokenClientAuthMethod.ClientSecretPost;
        }

        if (string.IsNullOrEmpty(ClientApp.ClientSecret)
            && ClientApp.TokenAuthMethod is TokenClientAuthMethod.ClientSecretPost or TokenClientAuthMethod.ClientSecretBasic)
        {
            ClientApp.TokenAuthMethod = TokenClientAuthMethod.None;
        }

        await PersistClientApp();
    }

    private async Task OnTokenAuthMethodChanged()
    {
        if (ClientApp.TokenAuthMethod == TokenClientAuthMethod.PrivateKeyJwt
            && string.IsNullOrWhiteSpace(ClientApp.SigningPrivateKeyJwk))
        {
            await LoadIllustrativeSigningKey();
            return;
        }

        await PersistClientApp();
    }

    private async Task PersistClientApp()
    {
        await SettingsRepository.SetClientAppModelAsync(ClientApp);
        await WorkspacePresets.MarkCustomAsync();
        await ClientAppChanged.InvokeAsync(ClientApp);
    }
}
