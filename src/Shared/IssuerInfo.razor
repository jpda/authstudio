@inject IPersistentSettingsRepository SettingsRepository
@inject HttpClient Http

<section class="panel">
    <div class="panel-header">
        <h2 class="panel-title">Issuer</h2>
        <button type="button" class="cimd-badge @CimdBadgeClass" disabled="@IsFetching"
            title="@CimdBadgeTitle" @onclick="RefreshDiscoveryAsync">
            @CimdBadgeLabel
        </button>
    </div>

    @if (!string.IsNullOrEmpty(FetchError))
    {
        <div class="alert alert-danger alert-sm" role="alert">@FetchError</div>
    }

    <details class="panel-details">
        <summary>Discovery notes &amp; common issuers</summary>
        <p class="panel-hint">
            Fetch OpenID configuration from <code>.well-known/openid-configuration</code>, or paste endpoints manually.
            <a href="https://openid.net/specs/openid-connect-discovery-1_0.html#ProviderConfig" target="_blank" rel="noopener">Spec</a>
        </p>
        <ul class="panel-hint-list">
            <li>Okta: <code>https://{domain}/oauth2/default</code></li>
            <li>Azure: <code>https://login.microsoftonline.com/{tenant}/v2.0</code></li>
        </ul>
    </details>

    <div class="field-grid">
        <label for="issuer">Issuer</label>
        <InputText id="issuer" class="form-control form-control-sm" @bind-Value="Issuer.Issuer"
            @bind-Value:after="PersistIssuer" />

        <label for="configUri">Configuration URL</label>
        <div class="input-group input-group-sm">
            <button class="btn btn-outline-secondary btn-sm" type="button" @onclick="RefreshDiscoveryAsync"
                disabled="@IsFetching">@FetchText</button>
            <InputText id="configUri" class="form-control form-control-sm" @bind-Value="Issuer.ConfigurationUri"
                @bind-Value:after="PersistIssuer" />
        </div>

        <label for="authorizeEndpoint">Authorize endpoint</label>
        <InputText id="authorizeEndpoint" class="form-control form-control-sm" @bind-Value="Issuer.AuthorizeEndpoint"
            @bind-Value:after="PersistIssuer" />

        <label for="tokenEndpoint">Token endpoint</label>
        <InputText id="tokenEndpoint" class="form-control form-control-sm" @bind-Value="Issuer.TokenEndpoint"
            @bind-Value:after="PersistIssuer" />
    </div>
</section>

@code {
    private string FetchText { get; set; } = "Fetch";
    private string? FetchError { get; set; }
    private bool IsFetching { get; set; }

    [Parameter]
    public IssuerModel Issuer { get; set; } = new IssuerModel();

    [Parameter]
    public EventCallback<IssuerModel> IssuerChanged { get; set; }

    private string CimdBadgeLabel => IsFetching ? "CIMD …" : Issuer.ClientIdMetadataDocumentSupported switch
    {
        true => "CIMD supported",
        false => "CIMD not supported",
        _ => "CIMD unknown"
    };

    private string CimdBadgeClass => IsFetching ? "cimd-checking" : Issuer.ClientIdMetadataDocumentSupported switch
    {
        true => "cimd-yes",
        false => "cimd-no",
        _ => "cimd-unknown"
    };

    private string CimdBadgeTitle => IsFetching
        ? "Fetching issuer configuration…"
        : "Click to refresh OpenID configuration and re-check CIMD support (client_id_metadata_document_supported)";

    private async Task RefreshDiscoveryAsync()
    {
        await FetchOpenIdConfiguration();
    }

    private async Task PersistIssuer()
    {
        await SettingsRepository.SetIssuerModelAsync(Issuer);
        await IssuerChanged.InvokeAsync(Issuer);
    }

    public async Task FetchOpenIdConfiguration()
    {
        if (string.IsNullOrWhiteSpace(Issuer.ConfigurationUri) && string.IsNullOrWhiteSpace(Issuer.Issuer))
        {
            FetchError = "Enter an issuer or configuration URL first.";
            return;
        }

        FetchError = null;
        IsFetching = true;
        FetchText = "…";
        try
        {
            var config = await OpenIdDiscovery.FetchAsync(Http, Issuer.Issuer, Issuer.ConfigurationUri);
            Issuer.Issuer = config.Issuer;
            Issuer.AuthorizeEndpoint = config.AuthorizationEndpoint;
            Issuer.TokenEndpoint = config.TokenEndpoint;
            Issuer.UserInfoEndpoint = config.UserInfoEndpoint;
            Issuer.JwksUri = config.JwksUri;
            Issuer.IntrospectionEndpoint = config.IntrospectionEndpoint;
            Issuer.ClientIdMetadataDocumentSupported = config.ClientIdMetadataDocumentSupported;
            Issuer.ConfigurationUri = string.Empty;
            await SettingsRepository.SetIssuerModelAsync(Issuer);
            await IssuerChanged.InvokeAsync(Issuer);
        }
        catch (Exception ex)
        {
            FetchError = ex.Message;
        }
        finally
        {
            IsFetching = false;
            FetchText = "Fetch";
        }
    }
}
