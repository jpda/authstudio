@page "/code"
@inject IHttpClientFactory ClientFactory
@inject NavigationManager NavigationManager
@inject ITransientRepository TransientRepository
@inject ClientAssertionService ClientAssertionService
@inject IWorkspaceSessionRepository WorkspaceSession

<PageTitle>Callback</PageTitle>

<h1 class="page-title">Token callback</h1>

@if (!string.IsNullOrEmpty(Error))
{
    <ErrorAlert Title="@Error" Message="@ErrorDescription" MoreInfoUri="@ErrorUri" />
}

@if (!string.IsNullOrEmpty(LoadError))
{
    <ErrorAlert Title="Could not restore authorization request" Message="@LoadError" Variant="warning" />
}

@if (string.IsNullOrEmpty(Error))
{
    <section class="panel">
        <h2 class="panel-title">Authorization response</h2>
        <div class="field-grid">
            <span>Issuer</span><code class="mono">@Issuer</code>
            <span>State</span><code class="mono">@State</code>
            <span>Client ID</span><code class="mono">@OriginalRequest.ClientApp.ClientId</code>
            <span>Token endpoint</span><code class="mono">@OriginalRequest.Issuer.TokenEndpoint</code>
            <span>Redirect URI</span><code class="mono">@OriginalRequest.ClientApp.RedirectUri</code>
            <span>Token auth</span><code class="mono">@OriginalRequest.ClientApp.TokenAuthMethod</code>
            @if (OriginalRequest.ClientApp.TokenAuthMethod == TokenClientAuthMethod.PrivateKeyJwt)
            {
                <span>Signing alg</span><code class="mono">@OriginalRequest.ClientApp.SigningAlgorithm</code>
            }
            <span>Code</span><code class="mono">@Code</code>
            @if (!string.IsNullOrEmpty(OriginalRequest.AuthorizeParameters.ResponseMode))
            {
                <span>Response mode</span><code class="mono">@OriginalRequest.AuthorizeParameters.ResponseMode</code>
            }
        </div>
        <div class="mt-2">
            <button class="btn btn-primary btn-sm" @onclick="RedeemCode"
                disabled="@(string.IsNullOrEmpty(Code) || IsRedeeming || !string.IsNullOrEmpty(LoadError))">
                @(IsRedeeming ? "Redeeming…" : "Redeem code")
            </button>
        </div>
    </section>

    @if (!string.IsNullOrEmpty(RedeemError))
    {
        <ErrorAlert Title="@RedeemError" Message="@RedeemErrorDescription" Detail="@RedeemErrorDetail"
            MoreInfoUri="@RedeemErrorUri" />
    }

    @if (!string.IsNullOrEmpty(Response))
    {
        <section class="panel mt-2">
            <h2 class="panel-title">Token response @(TokenStatusCode > 0 ? $"({TokenStatusCode})" : "")</h2>
            <pre class="mono url-display mb-0">@Response</pre>
        </section>
    }
    @if (!string.IsNullOrEmpty(LastClientAssertion))
    {
        <section class="panel mt-2">
            <h2 class="panel-title">Last client assertion</h2>
            <div class="url-display mono mb-2">@LastClientAssertion</div>
            <JwtInspector Jwt="@LastClientAssertion" Label="client assertion" />
        </section>
    }
}

<section class="panel mt-2">
    <h2 class="panel-title">Next round trip</h2>
    <p class="panel-hint mb-2">
        Start a fresh PKCE flow from the builder. Authorize regenerates the verifier and state automatically.
    </p>
    <a href="" class="btn btn-primary btn-sm">New authorize</a>
</section>

@if (!string.IsNullOrEmpty(Tokens.IdToken) || !string.IsNullOrEmpty(Tokens.AccessToken) ||
!string.IsNullOrEmpty(Tokens.RefreshToken))
{
    <TokenInfo Token="Tokens" />
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "code")]
    public string Code { get; set; } = "";

    [Parameter]
    [SupplyParameterFromQuery(Name = "state")]
    public string State { get; set; } = "";

    [Parameter]
    [SupplyParameterFromQuery(Name = "error")]
    public string Error { get; set; } = "";

    [Parameter]
    [SupplyParameterFromQuery(Name = "error_description")]
    public string ErrorDescription { get; set; } = "";

    [Parameter]
    [SupplyParameterFromQuery(Name = "error_uri")]
    public string ErrorUri { get; set; } = "";

    public string Issuer { get; set; } = "";
    public string Response { get; set; } = "";
    public string? LoadError { get; set; }
    public string? RedeemError { get; set; }
    public string? RedeemErrorDescription { get; set; }
    public string? RedeemErrorDetail { get; set; }
    public string? RedeemErrorUri { get; set; }
    public int TokenStatusCode { get; set; }
    public bool IsRedeeming { get; set; }
    public string LastClientAssertion { get; set; } = "";

    private AuthorizeRequestModel OriginalRequest = new AuthorizeRequestModel();
    public TokenResponseModel Tokens { get; set; } = new TokenResponseModel();

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(State))
        {
            LoadError = "No state parameter was provided. Start a new authorize request from the builder.";
        }
        else
        {
            OriginalRequest = await TransientRepository.GetAuthorizeRequestModelAsync(State);
            if (string.IsNullOrEmpty(OriginalRequest.Issuer.AuthorizeEndpoint)
                && string.IsNullOrEmpty(OriginalRequest.Issuer.TokenEndpoint)
                && string.IsNullOrEmpty(OriginalRequest.ClientApp.ClientId))
            {
                LoadError = $"No saved request found for state '{State}'. It may have expired or already been redeemed.";
            }
            else
            {
                Issuer = OriginalRequest.Issuer.Issuer;
            }
        }

        await base.OnInitializedAsync();
        LastClientAssertion = await WorkspaceSession.GetLastClientAssertionAsync() ?? "";
    }

    private async Task RedeemCode()
    {
        if (IsRedeeming)
        {
            return;
        }

        RedeemError = null;
        RedeemErrorDescription = null;
        RedeemErrorDetail = null;
        RedeemErrorUri = null;
        IsRedeeming = true;

        try
        {
            if (string.IsNullOrEmpty(OriginalRequest.Issuer.TokenEndpoint))
            {
                RedeemError = "token_endpoint_missing";
                RedeemErrorDescription = "The saved request does not include a token endpoint.";
                return;
            }

            var client = ClientFactory.CreateClient("AuthClient");
            string? clientAssertion = null;
            if (OriginalRequest.ClientApp.TokenAuthMethod == TokenClientAuthMethod.PrivateKeyJwt)
            {
                if (string.IsNullOrWhiteSpace(OriginalRequest.ClientApp.SigningPrivateKeyJwk))
                {
                    RedeemError = "missing_signing_key";
                    RedeemErrorDescription = "private_key_jwt requires a private JWK on the saved client configuration.";
                    return;
                }

                clientAssertion = await ClientAssertionService.CreateAssertionAsync(
                    OriginalRequest.ClientApp.ClientId,
                    OriginalRequest.Issuer.TokenEndpoint,
                    OriginalRequest.ClientApp.SigningPrivateKeyJwk,
                    OriginalRequest.ClientApp.SigningAlgorithm);
                LastClientAssertion = clientAssertion;
                await WorkspaceSession.SetLastClientAssertionAsync(clientAssertion);
            }

            using var request = TokenEndpointClient.BuildTokenRequest(
                OriginalRequest.Issuer.TokenEndpoint,
                OriginalRequest.ClientApp,
                OriginalRequest.AuthorizeParameters,
                OriginalRequest.PkceChallenge,
                Code,
                clientAssertion);

            using var tokenResponse = await client.SendAsync(request);
            var rawResponse = await tokenResponse.Content.ReadAsStringAsync();
            var result = TokenEndpointClient.ParseResponse(tokenResponse, rawResponse);

            Response = result.RawBody;
            TokenStatusCode = result.StatusCode;

            if (!result.IsSuccess)
            {
                RedeemError = result.Error;
                RedeemErrorDescription = result.ErrorDescription;
                RedeemErrorUri = result.ErrorUri;
                RedeemErrorDetail = rawResponse;
                return;
            }

            Tokens = result.Tokens ?? new TokenResponseModel();
            await TransientRepository.DeleteAuthorizeRequestModelAsync(State);
        }
        catch (Exception ex)
        {
            RedeemError = "token_request_failed";
            RedeemErrorDescription = ex.Message;
        }
        finally
        {
            IsRedeeming = false;
        }
    }
}
