@page "/"
@inject IPersistentSettingsRepository SettingsRepository
@inject ITransientRepository TransientRepository
@inject NavigationManager NavigationManager
@inject OAuthBuilderActions BuilderActions
@inject WorkspacePresetService WorkspacePresets
@implements IDisposable

<PageTitle>Builder</PageTitle>

<WorkspacePresetBar ClientApp="ClientApp" ClientAppChanged="HandleClientAppChanged" />

<div class="builder-grid">
    <div class="builder-config">
        <IssuerInfo Issuer="Issuer" IssuerChanged="HandleIssuerChanged" />
        <ClientAppInfo Issuer="Issuer" ClientApp="ClientApp" ClientAppChanged="HandleClientAppChanged" />
        <PkceChallenge @bind-Pkce="PkceChallenge" />
        <OAuthParamsEditor RequestId="@RequestId" AuthorizeParameters="AuthorizeParameters"
            AuthorizeParametersChanged="StateHasChanged" />
    </div>
    <div class="builder-output">
        <AuthorizeUrlPanel Request="CurrentRequest" OnAuthorize="StartAuthorizeAsync" />
    </div>
</div>

@code {
    public IssuerModel Issuer { get; set; } = new IssuerModel()
    {
        Issuer = "https://login.sck.sh",
    };
    public PkceChallengeModel PkceChallenge { get; set; } = new PkceChallengeModel();
    public ClientAppModel ClientApp { get; set; } = new ClientAppModel();
    public AuthorizeParameterModel AuthorizeParameters { get; set; } = new AuthorizeParameterModel()
    {
        ScopeParameter = "openid profile",
        ResponseType = "code"
    };

    private string RequestId { get; set; } = Guid.NewGuid().ToString("N");

    private AuthorizeRequestModel CurrentRequest => new()
    {
        Id = RequestId,
        Issuer = Issuer,
        ClientApp = ClientApp,
        PkceChallenge = PkceChallenge,
        AuthorizeParameters = AuthorizeParameters
    };

    protected override async Task OnInitializedAsync()
    {
        var issuerTask = SettingsRepository.GetIssuerModelAsync();
        var pkceTask = SettingsRepository.GetPkceChallengeModelAsync();
        var clientTask = SettingsRepository.GetClientAppModelAsync();
        var paramsTask = SettingsRepository.GetAuthorizeParameterModelAsync();
        await Task.WhenAll(issuerTask, pkceTask, clientTask, paramsTask);

        Issuer = await issuerTask ?? Issuer;
        PkceChallenge = await pkceTask ?? PkceChallenge;
        ClientApp = await clientTask ?? ClientApp;
        AuthorizeParameters = await paramsTask ?? AuthorizeParameters;

        await ApplyCimdClientIdIfNeeded();

        BuilderActions.IsBuilderActive = true;
        BuilderActions.AuthorizeAsync = StartAuthorizeAsync;

        await base.OnInitializedAsync();
    }

    private async Task HandleIssuerChanged(IssuerModel issuer)
    {
        Issuer = issuer;
        await ApplyCimdClientIdIfNeeded();
    }

    private Task HandleClientAppChanged(ClientAppModel clientApp)
    {
        ClientApp = clientApp;
        return Task.CompletedTask;
    }

    private async Task ApplyCimdClientIdIfNeeded()
    {
        if (!CimdDefaults.ShouldDefaultClientId(ClientApp.ClientId, Issuer.ClientIdMetadataDocumentSupported))
        {
            return;
        }

        ClientApp.ClientId = CimdDefaults.GetDocumentUrl(NavigationManager);
        await SettingsRepository.SetClientAppModelAsync(ClientApp);
    }

    private async Task StartAuthorizeAsync()
    {
        PkceChallenge.GenerateChallenge();
        await SettingsRepository.SetPkceChallengeModelAsync(PkceChallenge);
        RequestId = Guid.NewGuid().ToString("N");

        var request = CurrentRequest;
        await SettingsRepository.SetAuthorizeParameterModelAsync(AuthorizeParameters);
        await TransientRepository.SetAuthorizeRequestModelAsync(request);
        NavigationManager.NavigateTo(request.AuthorizeUrl);
    }

    public void Dispose()
    {
        BuilderActions.IsBuilderActive = false;
        BuilderActions.AuthorizeAsync = null;
    }
}
